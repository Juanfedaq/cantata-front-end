# URL base da API do backend (cantata-back-end)
VITE_API_URL=http://localhost:3000

# Client ID do "Entrar com o Google" (Google Cloud Console → Credentials).
# Exceção deliberada à regra de só VITE_API_URL neste .env: Client ID OAuth
# não é segredo — vai embutido no bundle JS de qualquer forma (é assim que o
# Google Identity Services funciona); o mesmo valor está no GOOGLE_CLIENT_ID
# do backend. Vazio = o botão de login com Google não aparece.
VITE_GOOGLE_CLIENT_ID=
