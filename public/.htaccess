# Fallback de SPA (Apache/LiteSpeed — Hostinger):
# qualquer rota que não seja um arquivo/pasta real cai no index.html,
# para os deep links dos e-mails (/verify-email, /reset-password) funcionarem.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  # Páginas pré-renderizadas (vite-ssg): /privacidade serve privacidade.html
  # com a URL limpa — crawlers recebem o HTML pronto, sem executar JS.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+)$ /$1.html [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
