# Usado automaticamente pelo Vite no `npm run build` (modo production).
# O .env (dev) continua apontando para localhost — este arquivo garante que
# NENHUM build de produção saia com localhost embutido (o site no ar chamando
# localhost dispara o prompt de "acessar apps neste dispositivo" do Chrome
# e nenhuma chamada à API funciona).
VITE_API_URL=https://api.cantata.com.br
